<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="8dp"
            android:text="@string/main_title"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Headline6" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="4dp"
            android:text="@string/section_sdk"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_sdk_init"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_sdk_init" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:paddingBottom="4dp"
            android:text="@string/section_prefs"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_pref_save_duration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_pref_save_duration" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_pref_read_duration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_pref_read_duration" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_pref_save_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_pref_save_type" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_pref_read_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_pref_read_type" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:paddingBottom="4dp"
            android:text="@string/section_scheduler"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_slot_compute"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_slot_compute" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_alarm_schedule"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_alarm_schedule" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_alarm_cancel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_alarm_cancel" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:paddingBottom="4dp"
            android:text="@string/section_tracking_periodic"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_track_periodic_ppg25_acc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_track_periodic_ppg25_acc" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_track_periodic_ppg100"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_track_periodic_ppg100" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_track_periodic_acc_only"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_track_periodic_acc_only" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:paddingBottom="4dp"
            android:text="@string/section_tracking_ondemand"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_track_ondemand_ppg_acc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_track_ondemand_ppg_acc" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_track_ondemand_ecg_acc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_track_ondemand_ecg_acc" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_track_ondemand_ppg100"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_track_ondemand_ppg100" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:paddingBottom="4dp"
            android:text="@string/section_service"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_service_stop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_service_stop" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:paddingBottom="4dp"
            android:text="@string/section_log"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1" />

        <TextView
            android:id="@+id/log_output"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#E8E8E8"
            android:fontFamily="monospace"
            android:minHeight="180dp"
            android:padding="8dp"
            android:textIsSelectable="true"
            android:textSize="11sp"
            tools:text="로그…" />
    </LinearLayout>
</ScrollView>
